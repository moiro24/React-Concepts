# ---------------------------------------------------------------------------
# Firebase Web App config.
#
# 1. Copy this file to `.env.local`   (that file is gitignored — keys stay local)
# 2. Paste the values from your Firebase Console:
#      Project settings ⚙️  →  Your apps  →  Web app  →  SDK setup & config
# 3. Restart `npm run dev` after editing env files.
#
# NOTE: these Firebase web keys are safe to expose in the browser. Access is
# controlled by Firebase Security Rules, not by keeping these secret.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
